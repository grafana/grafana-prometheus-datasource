{
  "author": "Grafana Labs",
  "license": "AGPL-3.0-only",
  "name": "@grafana/prometheus",
  "version": "13.1.8",
  "description": "Grafana Prometheus Library",
  "packageManager": "yarn@4.17.1",
  "keywords": [
    "typescript",
    "prometheus",
    "grafana"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/grafana/grafana-prometheus-datasource.git",
    "directory": "packages/grafana-prometheus"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "files": [
    "./dist",
    "./README.md",
    "./CHANGELOG.md",
    "./LICENSE_AGPL"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p ./tsconfig.build.json && rollup -c rollup.config.ts --configPlugin esbuild",
    "bundle": "rollup -c rollup.config.ts --configPlugin esbuild",
    "clean": "rimraf ./dist ./compiled ./package.tgz",
    "test": "jest --config jest.config.js --watch --onlyChanged",
    "test:ci": "jest --config jest.config.js --passWithNoTests --maxWorkers 4",
    "typecheck": "tsc --emitDeclarationOnly false --noEmit",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix . && prettier --write --list-different ."
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@floating-ui/react": "0.27.20",
    "@grafana/plugin-ui": "0.17.2",
    "@hello-pangea/dnd": "18.0.1",
    "@leeoniya/ufuzzy": "1.0.19",
    "@lezer/common": "1.5.2",
    "@lezer/highlight": "1.2.3",
    "@lezer/lr": "1.4.10",
    "@prometheus-io/lezer-promql": "0.313.1",
    "debounce-promise": "3.1.2",
    "lodash": "4.18.1",
    "monaco-editor": "0.56.0",
    "monaco-promql": "1.9.0",
    "pluralize": "8.0.0",
    "prismjs": "1.30.0",
    "react-highlight-words": "0.21.0",
    "react-use": "17.6.1",
    "react-window": "1.8.11",
    "rxjs": "7.8.2",
    "semver": "7.8.5",
    "uuid": "14.0.1"
  },
  "devDependencies": {
    "@grafana/assistant": "0.1.30",
    "@grafana/data": "13.1.1",
    "@grafana/e2e-selectors": "13.1.1",
    "@grafana/i18n": "13.1.1",
    "@grafana/runtime": "13.1.1",
    "@grafana/schema": "13.1.1",
    "@grafana/ui": "13.1.1",
    "@rollup/plugin-commonjs": "28.0.9",
    "@rollup/plugin-dynamic-import-vars": "2.1.5",
    "@rollup/plugin-image": "3.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/debounce-promise": "3.1.9",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/node": "24.13.3",
    "@types/pluralize": "0.0.33",
    "@types/prismjs": "1.26.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/react-highlight-words": "0.20.1",
    "@types/react-window": "1.8.8",
    "@types/semver": "7.7.1",
    "esbuild": "0.28.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-select-event": "5.5.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-node-externals": "8.1.2",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "@grafana/data": "13.1.1",
    "@grafana/e2e-selectors": "13.1.1",
    "@grafana/i18n": "13.1.1",
    "@grafana/runtime": "13.1.1",
    "@grafana/schema": "13.1.1",
    "@grafana/ui": "13.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "@grafana/data": "$@grafana/data",
    "@grafana/schema": "$@grafana/schema",
    "@grafana/i18n": "$@grafana/i18n"
  },
  "engines": {
    "node": ">=24"
  }
}
